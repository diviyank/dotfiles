{
    "modules-left": ["hyprland/workspaces", "hyprland/mode"],
    "modules-center": ["clock", "idle_inhibitor","custom/pomodoro"],
    "modules-right": [ "custom/spotify","tray", "custom/scratchpad-indicator", "pulseaudio", "custom/power"],

    "hyprland/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) ",
        "format-ethernet": "{ifname} ",
        "format-disconnected": "", 
        "max-length": 50,
        "on-click": "kitty -e 'nmtui'"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "",
            "deactivated": ""
        },
    },
    "tray": {
        "icon-size": 15,
        "spacing": 10
    },
	"clock": {
	    "format": "{:%A %d %b   %H:%M}",
	    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
	    "on-click": "gnome-calendar"
	},
    "pulseaudio": {
        "format": "{volume}% {icon} ",
        "format-bluetooth": "{volume}% {icon} {format_source}",
        "format-bluetooth-muted": " {icon} {format_source}",
        "format-muted": "0% {icon} ",
        "format-source": "{volume}% ",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    },
    "custom/power": {
		"format": " ",
		"on-click": "wlogout"
	},
    "custom/spotify": {
	"return-type":"json",
        "format": "    {}  ",
        "max-length": 40,
        "exec": "$HOME/.config/waybar/mediaplayer.sh", // Script in resources folder
        "exec-if": "pgrep spotify"
        "escape": true,
    },
    "custom/pomodoro": {
        "return-type": "json",
        "interval": 1,
        "exec": "$HOME/.config/waybar/pomodoro.sh",
        "on-click": "$HOME/.config/waybar/pomodoro.sh toggle",
        "format": "{}"
    },
}
