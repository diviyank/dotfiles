
# RELOAD CONFIG
ctrl + alt + cmd - r : launchctl kickstart -k "gui/${UID}/homebrew.mxcl.yabai"

# CHANGE LAYOUT (Fixed path for jq and yabai)
ctrl + shift - space : /opt/homebrew/bin/yabai -m space --layout "$(/opt/homebrew/bin/yabai -m query --spaces --space | /opt/homebrew/bin/jq -r 'if .type == "bsp" then "stack" else "bsp" end')"

# FOCUS WINDOW
cmd - up    : /opt/homebrew/bin/yabai -m window --focus north
cmd - left  : /opt/homebrew/bin/yabai -m window --focus west
cmd - right : /opt/homebrew/bin/yabai -m window --focus east
cmd - down  : /opt/homebrew/bin/yabai -m window --focus south

# FOCUS SPACES (Using Keycodes 0x12-0x1D to ensure it works on AZERTY/QWERTY)
cmd - 0x12 : /opt/homebrew/bin/yabai -m space --focus one
cmd - 0x13 : /opt/homebrew/bin/yabai -m space --focus two
cmd - 0x14 : /opt/homebrew/bin/yabai -m space --focus three
cmd - 0x15 : /opt/homebrew/bin/yabai -m space --focus four
cmd - 0x17 : /opt/homebrew/bin/yabai -m space --focus five
cmd - 0x16 : /opt/homebrew/bin/yabai -m space --focus six
cmd - 0x1A : /opt/homebrew/bin/yabai -m space --focus seven
cmd - 0x1C : /opt/homebrew/bin/yabai -m space --focus eight
cmd - 0x19 : /opt/homebrew/bin/yabai -m space --focus nine
cmd - 0x1D : /opt/homebrew/bin/yabai -m space --focus ten

# MOVE WINDOW TO SPACE
cmd + shift - 0x12 : /opt/homebrew/bin/yabai -m window --space one; /opt/homebrew/bin/yabai -m space --focus one
cmd + shift - 0x13 : /opt/homebrew/bin/yabai -m window --space two; /opt/homebrew/bin/yabai -m space --focus two
cmd + shift - 0x14 : /opt/homebrew/bin/yabai -m window --space three; /opt/homebrew/bin/yabai -m space --focus three
cmd + shift - 0x15 : /opt/homebrew/bin/yabai -m window --space four; /opt/homebrew/bin/yabai -m space --focus four
cmd + shift - 0x17 : /opt/homebrew/bin/yabai -m window --space five; /opt/homebrew/bin/yabai -m space --focus five
cmd + shift - 0x16 : /opt/homebrew/bin/yabai -m window --space six; /opt/homebrew/bin/yabai -m space --focus six
cmd + shift - 0x1A : /opt/homebrew/bin/yabai -m window --space seven; /opt/homebrew/bin/yabai -m space --focus seven
cmd + shift - 0x1C : /opt/homebrew/bin/yabai -m window --space eight; /opt/homebrew/bin/yabai -m space --focus eight
cmd + shift - 0x19 : /opt/homebrew/bin/yabai -m window --space nine; /opt/homebrew/bin/yabai -m space --focus nine
cmd + shift - 0x1D : /opt/homebrew/bin/yabai -m window --space ten; /opt/homebrew/bin/yabai -m space --focus ten

# FULLSCREEN
ctrl - f : /opt/homebrew/bin/yabai -m window --toggle zoom-fullscreen

# MOVE WINDOW DISPLAY (Fixed Paths)
cmd + shift + ctrl - left : WIN_ID=$(/opt/homebrew/bin/yabai -m query --windows --window | /opt/homebrew/bin/jq '.id'); /opt/homebrew/bin/yabai -m window --swap west; [[ ! $? == 0 ]] && (/opt/homebrew/bin/yabai -m display --focus west; /opt/homebrew/bin/yabai -m window last --insert east; /opt/homebrew/bin/yabai -m window --focus $WIN_ID; /opt/homebrew/bin/yabai -m window --display prev; /opt/homebrew/bin/yabai -m window --focus $WIN_ID)

cmd + shift + ctrl - right : WIN_ID=$(/opt/homebrew/bin/yabai -m query --windows --window | /opt/homebrew/bin/jq '.id'); /opt/homebrew/bin/yabai -m window --swap east; [[ ! $? == 0 ]] && (/opt/homebrew/bin/yabai -m display --focus east; /opt/homebrew/bin/yabai -m window first --insert west; /opt/homebrew/bin/yabai -m window --focus $WIN_ID; /opt/homebrew/bin/yabai -m window --display next; /opt/homebrew/bin/yabai -m window --focus $WIN_ID)

# TERMINAL
cmd - return : open -na /Applications/kitty.app/Contents/MacOS/kitty
# Toggle Scratchpad
cmd - tab : scratchpad --toggle kitty
# cmd - tab : ~/.config/yabai/scripts/scratchpad.sh
